---
/* Mappa radiale: l'area al centro, i suoi argomenti su un anello (porta maps.js). */
import type { Area } from "../data/types";
import { topicsOfArea } from "../data/course";
import { shade } from "../lib/mapgeom";
import MapNode from "./MapNode.astro";

interface Props {
  area: Area;
}
const { area } = Astro.props;
const topics = topicsOfArea(area.id);
const n = topics.length;
const nodeW = 152;
// Raggio dell'anello: grande abbastanza che gli spicchi adiacenti non si tocchino.
const R = n <= 1 ? 0 : Math.max(200, (nodeW + 36) / (2 * Math.sin(Math.PI / n)));
const padX = nodeW / 2 + 50;
const padY = 64;
const W = Math.round(2 * R + 2 * padX);
const H = Math.round(2 * R + 2 * padY);
const cx = W / 2;
const cy = H / 2;
const pointAt = (i: number) => {
  const a = (i / n) * Math.PI * 2 - Math.PI / 2;
  return { x: cx + R * Math.cos(a), y: cy + R * Math.sin(a) };
};
const ring = topics.map((t, i) => ({ t, ...pointAt(i) }));
---

<div class="mapwrap">
  <svg class="map" viewBox={`0 0 ${W} ${H}`} width={W} height={H}>
    {ring.map((p) => <line class="edge" x1={cx} y1={cy} x2={p.x} y2={p.y} />)}
    <MapNode x={cx} y={cy} label={area.title} color={area.color} area={area.id} hub />
    {
      ring.map((p) => (
        <MapNode x={p.x} y={p.y} label={p.t.title} color={shade(area.color, 0.5)} topic={p.t.id} />
      ))
    }
  </svg>
</div>
